# 复制此文件为 .env 并填写真实值
DEBUG=false
DATABASE_URL=sqlite:///./data/ops_platform.db
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
# 生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480
NMAP_PATH=nmap
IPERF3_PATH=iperf3

# ── 钉钉机器人 ──
# Webhook 地址（必填，创建机器人后获取）
DINGTALK_WEBHOOK_URL=
# 签名密钥（可选，机器人安全设置中选择"加签"后获取）
DINGTALK_SECRET=

# ── Zabbix 监控集成 ──
# Zabbix Web 地址，例如 http://zabbix.example.com
ZABBIX_URL=
# API Token（Zabbix 7.x 推荐，在 User → API tokens 中创建）
ZABBIX_API_TOKEN=
# 若不使用 Token，可改用 用户名 + 密码 认证
ZABBIX_USER=
ZABBIX_PASSWORD=
# 是否验证 SSL 证书（自签名证书设为 false）
ZABBIX_VERIFY_SSL=false
# API 响应缓存时间（秒），减少 Zabbix 压力
ZABBIX_CACHE_TTL=60
# API 请求超时（秒）
ZABBIX_TIMEOUT=10
